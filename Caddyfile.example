# ============================================================
#  Caddy 反向代理配置（支持自动 HTTPS）
#  复制为 Caddyfile 使用
# ============================================================

sub.example.com {
    # 前端
    handle /sub* {
        reverse_proxy subconverter:25500
    }
    handle /version* {
        reverse_proxy subconverter:25500
    }
    handle /getprofile* {
        reverse_proxy subconverter:25500
    }
    handle /updateconf* {
        reverse_proxy subconverter:25500
    }

    # 后端 + 其他请求
    handle {
        reverse_proxy subweb:80
    }

    # 自动 HTTPS
    tls {
        protocols tls1.2 tls1.3
    }

    # 压缩
    encode gzip

    # 日志
    log {
        output file /data/access.log
    }
}
